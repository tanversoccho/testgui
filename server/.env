# LIVE Oracle configuration. Created for first real-DB read test.
# Reads are safe — no writes get issued unless you explicitly call
# POST /cartons, /reprint, DELETE /cartons, or /batches/finalize.

DIKAI_HOST=0.0.0.0
DIKAI_PORT=8000

# ---- Mode: LIVE ORACLE ----
DIKAI_USE_MOCK_DB=false

# ---- Oracle target (same creds as dikai_config.json) ----
DIKAI_DB_HOST=192.168.20.20
DIKAI_DB_PORT=1601
DIKAI_DB_SERVICE=FUNC80
DIKAI_DB_USER=apps
DIKAI_DB_PASSWORD=apps123
DIKAI_USE_THICK_MODE=true
DIKAI_ORACLE_INSTANT_CLIENT_PATH=C:/Users/amits/Downloads/Dikai_GUI_final/instantclient_23_0
DIKAI_TNS_ADMIN_PATH=

# ---- Pool ----
DIKAI_DB_POOL_MIN=2
DIKAI_DB_POOL_MAX=8
DIKAI_DB_POOL_INCREMENT=1
DIKAI_DB_POOL_WAIT_SECONDS=10
DIKAI_DB_STMT_TIMEOUT_SECONDS=30

# ---- Rate limit ----
DIKAI_RATE_LIMIT_PER_SECOND=20
DIKAI_RATE_LIMIT_BURST=40

# ---- Idempotency ----
DIKAI_IDEMPOTENCY_TTL_SECONDS=86400
DIKAI_IDEMPOTENCY_MAX_ENTRIES=10000

# ---- Printer TCP counter source ----
DIKAI_PRINTER_PROTO=TCP
DIKAI_PRINTER_IP=192.168.1.110
DIKAI_PRINTER_PORT=4916
DIKAI_PRINTER_TIMEOUT=2.0

# ---- Auth ----
DIKAI_AUTH_TOKEN_TTL_SECONDS=28800

# ---- Devices ----
DIKAI_DEVICES_RAW=stm32-test:test,stm32-line-A-01:dev-secret-1,stm32-line-A-02:dev-secret-2

# ---- Brands ----
DIKAI_BRANDS_RAW=Monalisa:089:481,X Monica:063:369,Alexander:064:370,X Tiles:093:522,Venus:062:368
